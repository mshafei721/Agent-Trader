# ====================================================================
# goldtrader configuration — copy to .env and fill in.
# .env is gitignored. NEVER commit real credentials.
# ====================================================================

# ---------- MetaTrader 5 ----------
# Leave login/password/server blank to attach to the ALREADY-RUNNING,
# logged-in terminal (recommended on this machine). Fill them only to
# have the library log in itself.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# Optional explicit path to terminal64.exe (blank = auto-detect running terminal)
MT5_TERMINAL_PATH=

# ---------- Symbol mapping ----------
# Broker gold symbol (this account resolved to XAUUSD). Comma-separated fallbacks tried in order.
MT5_SYMBOL_CANDIDATES=XAUUSD,GOLD,XAUUSDm,XAUUSD.,GOLDmicro,#XAUUSD
# Ticker handed to TradingAgents for data (Yahoo gold futures continuous).
YAHOO_TICKER=GC=F

# ---------- LLM endpoint ----------
# Default: Anthropic API directly (clean, natively supported by TradingAgents).
# Put your Anthropic key in LLM_API_KEY. Leave LLM_BACKEND_URL blank for the default endpoint.
# Alternatives (swap these lines only):
#   OpenAI:  LLM_PROVIDER=openai  LLM_BACKEND_URL=https://api.openai.com/v1  LLM_API_KEY=sk-...
#   Ollama:  LLM_PROVIDER=ollama  LLM_BACKEND_URL=http://localhost:11434/v1
LLM_PROVIDER=anthropic
LLM_BACKEND_URL=
LLM_API_KEY=
LLM_DEEP_MODEL=claude-sonnet-4-6
LLM_QUICK_MODEL=claude-haiku-4-5
LLM_REQUEST_TIMEOUT_S=180
PROMPT_CACHE_ENABLED=true      # cache repeated prompt prefixes within a run
PROMPT_CACHE_TTL=5m            # 5m (cheaper) | 1h

# ---------- Risk ----------
RISK_PCT_PER_TRADE=0.5        # % of equity risked per trade
MAX_OPEN_POSITIONS=3          # max simultaneous positions (pyramiding into winners)
MAX_TOTAL_RISK_PCT=1.5        # hard cap on summed open risk across all positions
PYRAMID_WINNERS_ONLY=true     # only add a same-direction position if existing ones are in profit
MAX_DAILY_LOSS_PCT=2.0        # halt for the day at this drawdown
MAX_TOTAL_LOSS_PCT=10.0       # write kill-switch + exit at this drawdown
MIN_CONFIDENCE=0.55           # below -> HOLD
ATR_PERIOD=14
ATR_SL_MULT=1.5
ATR_TP_MULT=2.0
SL_MODE=atr                   # atr | fixed
STOP_TIMEFRAME=M30            # ATR stop sized from this timeframe (matches the trigger)
FIXED_SL_POINTS=500           # used when SL_MODE=fixed (gold: 500pts = $5.00)
FIXED_TP_POINTS=1000
DEVIATION_POINTS=20           # slippage tolerance
MAGIC=770077

# ---------- Volatility gate (used by RiskManager) ----------
REGIME_FILTER_ENABLED=true
ADX_PERIOD=14
ADX_MIN_TREND=18              # H1 ADX floor enforced by the technical engine
ATR_MAX_PCT=2.0               # ATR/price% above this -> too wild, skip
HTF_TREND_CONFIRM=true        # legacy; confluence now lives in the technical engine

# ---------- Two-speed strategy ----------
BIAS_REFRESH_HOURS=4          # LLM bias refresh cadence
FILTER_TIMEFRAME=H4           # macro trend filter
SETUP_TIMEFRAME=H1            # setup confirmation
TRIGGER_TIMEFRAME=M30         # entry trigger
MIN_CONVICTION=0.55           # (must-agree mode only; inactive in charts-lead)
BIAS_VETO_CONVICTION=0.75     # charts lead; LLM blocks a trade only if opposite at >= this conviction

# ---------- Technical indicators ----------
EMA_FAST=20
EMA_SLOW=50
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# ---------- Trade management (fast loop) ----------
USE_TRAILING=true
BREAKEVEN_AT_R=0.5           # move SL to entry at +0.5R (protect winners sooner)
TRAIL_ATR_MULT=1.5          # Chandelier trail: swing extreme -/+ 1.5x ATR
CHANDELIER_LOOKBACK=22      # bars for the swing extreme in the trail
PARTIAL_TP_R=1.0            # close half at +1R, trail the rest (0 = off)
# Early loss-cut (fast loop): close a loser before the full stop if momentum flips
CUT_LOSS_ENABLED=true
CUT_LOSS_AT_R=0.5           # only consider cutting once down 0.5R
CUT_LOSS_TIMEFRAME=M15     # timeframe whose trend must oppose the position to cut
CUT_LOSS_SIGNAL=either     # ema | macd | either (either = looser/faster trigger)
MANAGE_INTERVAL_SECONDS=60 # fast trade-management cadence (entries stay on INTERVAL_MINUTES)

# ---------- Bias-aware exit (fast loop, uses CACHED bias) ----------
BIAS_EXIT_ENABLED=true
BIAS_EXIT_CONVICTION=0.6    # close/tighten when the cached LLM bias opposes the trade at >= this
BIAS_EXIT_ACTION=close      # close | tighten

# ---------- Reflection / self-heal / learning ----------
REFLECTION_ENABLED=true
REFLECTION_MIN_TRADES=20    # LLM suggestions gated until this many closed trades
REFLECTION_EVERY_N_TRADES=20
REFLECTION_DAILY=true
REFLECTION_USE_LLM=true
DEFENSIVE_LOSS_STREAK=4     # consecutive losers -> halve risk (auto)
DEFENSIVE_PAUSE_STREAK=6    # consecutive losers -> pause new entries (auto)

# ---------- Cadence ----------
INTERVAL_MINUTES=15           # fast loop runs every 15 min (M30 trigger)
SKIP_WEEKENDS=true
TICK_STALE_MINUTES=10         # tick older than this -> treat market as closed

# ---------- Safety ----------
REQUIRE_DEMO=true             # refuse to run on a non-demo account
DRY_RUN=true                  # compute + order_check but DO NOT send orders

# ---------- Live-safety gates (V7 Phase 0) ----------
SPREAD_GUARD_ENABLED=true     # reject new entries when the live spread blows out
MAX_ENTRY_SPREAD_POINTS=50    # broker points (gold: ~50pts = $0.50 = 5 pips). Tune per broker.
NEWS_BLACKOUT_ENABLED=true    # block entries around high-impact USD events (FAILS CLOSED)
NEWS_BLACKOUT_PRE_MINUTES=30  # blackout starts this long before an event
NEWS_BLACKOUT_POST_MINUTES=15 # blackout ends this long after an event
FINNHUB_API_KEY=              # optional; ForexFactory free JSON is the default source
CALENDAR_REFRESH_MINUTES=60   # how often to re-pull the weekly calendar (cached to disk)
SESSION_FILTER_ENABLED=true   # only OPEN new entries in the liquid London-NY overlap
TRADING_SESSION_START_UTC=7   # entries allowed from this UTC hour ...
TRADING_SESSION_END_UTC=17    # ... until this UTC hour (management runs 24/5 regardless)
WEEKEND_FLAT_ENABLED=true     # flatten all positions before the Friday close (no Monday gap-through)
WEEKEND_FLAT_HOUR_UTC=20      # Friday flatten cutoff (UTC hour) ...
WEEKEND_FLAT_MINUTE_UTC=30    # ... and minute (20:30 UTC, before the ~21:00 close)
MONDAY_GRACE_MINUTES=30       # skip new entries this long after the Sunday ~22:00 UTC reopen
MAX_LOTS_ABSOLUTE=1.0         # hard lot cap regardless of equity growth (0 = disabled)

# ---------- Gold-native data feeds (V7 Phase 1) ----------
COT_GATE_ENABLED=true         # block entries that chase a crowded CFTC positioning extreme
COT_EXTREME_Z=1.5             # block longs at net z > +z, shorts at z < -z (FAILS OPEN if no data)
COT_CONTRACT_CODE=088691      # COMEX gold CFTC market code
COT_REFRESH_HOURS=24          # COT is weekly; re-check at most this often
# Bias-input overhaul: inject gold-commodity framing + macro/COT/news into the LLM bias prompt.
BIAS_CONTEXT_INJECTION_ENABLED=true
FRED_API_KEY=                 # free key from fredgraph.stlouisfed.org; macro context skipped if blank
NEWS_RSS_URLS=https://www.fxstreet.com/rss/news,https://feeds.marketwatch.com/marketwatch/marketpulse/
NEWS_DIGEST_COUNT=8           # number of gold-relevant headlines fed into the bias context

# ---------- Sizing-overlay ensemble (V7; damp-only, compose with self-heal) ----------
SEASONAL_BIAS_ENABLED=true        # winter (Nov-Apr) long tilt: full size in winter, damped off-season
SEASONAL_OFFSEASON_SCALER=0.6     # size factor for non-winter-long entries
TSMOM_REGIME_ENABLED=true         # damp new LONGS in a ~12-month gold downtrend (halves drawdown)
TSMOM_REGIME_LOOKBACK_DAYS=252    # ~12 trading months
TSMOM_DOWNTREND_SCALER=0.5        # long size factor while in a 12mo downtrend
VOL_TARGET_ENABLED=true           # damp size when realized annual vol exceeds the target (tail control)
VOL_TARGET_ANNUAL=0.18            # annualized vol target; damp above it
VOL_LOOKBACK_DAYS=20

# ---------- Entry trigger (M30 timing within the H4/H1 gate) ----------
ENTRY_TRIGGER=macd_cross          # macd_cross (default, selective) | donchian | pullback (lab-tested)
DONCHIAN_LOOKBACK=20              # breakout channel bars (when ENTRY_TRIGGER=donchian)
PULLBACK_EMA=50                  # M30 EMA the pullback must touch (when ENTRY_TRIGGER=pullback)

# ---------- Seasonal-core allocation mode (V7; OFF by default) ----------
# When true, REPLACES intraday trading with a low-frequency long-gold ALLOCATION sized by the
# overlay stack (winter x TSMOM x vol-target). Lab-validated. Dry-run first, then restart.
CORE_ALLOCATION_ENABLED=false
CORE_BASE_LOTS=0.10               # lots at full (1.0) exposure; clamped by MAX_LOTS_ABSOLUTE
CORE_REBALANCE_THRESHOLD=0.10     # min exposure change before it rebalances (anti-churn)
CORE_CATASTROPHIC_STOP_PCT=20.0   # wide backstop stop below entry (held, no take-profit)

# ---------- Broker-truth reconciliation ----------
RECONCILE_HISTORY_DAYS=90         # how far back to scan MT5 deals when syncing closed-trade P&L

# ---------- Backtest / validation lab (V7 Phase 2; lab only, no live effect) ----------
BACKTEST_BARS=6000
BACKTEST_WARMUP_BARS=250
BACKTEST_COST_SPREAD_POINTS=30
BACKTEST_COST_SLIPPAGE_POINTS=5
BACKTEST_SEED=42
BACKTEST_MODEL_MANAGEMENT=true
BACKTEST_DUKASCOPY_YEARS=5

# ---------- Dashboard (localhost monitoring UI) ----------
DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1          # loopback only — never expose
DASHBOARD_PORT=8787
DASHBOARD_LOG_TAIL_LINES=200
DASHBOARD_POSITIONS_CACHE_SECONDS=4.0
DASHBOARD_TOKEN=                  # optional token for control POSTs (blank = no auth, loopback only)

# ---------- Notifications (optional) ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
